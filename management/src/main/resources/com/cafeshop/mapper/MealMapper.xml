<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cafeshop.mapper.MealMapper">
    <!--查詢全部餐點-->
    <select id="getMeals" resultType="com.cafeshop.Menu.Meal">

        SELECT
            id,
            theme_id,
            name,
            price,
            description,
            image_url,
            count,
            is_sale,
            create_time,
            update_time
        FROM meal

    </select>
    <!--查詢單一餐點-->
    <select id="getMealById" resultType="com.cafeshop.Menu.Meal">

        SELECT
            id,
            theme_id,
            name,
            price,
            description,
            image_url,
            count,
            is_sale,
            create_time,
            update_time
        FROM meal
        WHERE id = #{id}

    </select>
    <!--新增餐點-->
    <insert id="postMeal" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO meal (theme_id, name,price,description,image_url,count,is_sale)
        VALUES (#{themeId}, #{name} , #{price} , #{description} , #{imageUrl} , #{count} , #{isSale})
    </insert>
    <!--建立餐點與選項的關聯-->
    <insert id="insertMealOptions">
        INSERT INTO meal_option_map (meal_id, group_id)
        VALUES
        <foreach collection="groupIds" item="groupId" separator=",">
            (#{mealId}, #{groupId})
        </foreach>
    </insert>
    <!--取得餐點選擇的選項Id-->
    <select id="getMealOptionIds" resultType="java.lang.Long">

        SELECT group_id
        FROM meal_option_map
        WHERE meal_id = #{mealId}

    </select>

</mapper>